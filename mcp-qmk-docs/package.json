{
  "name": "mcp-qmk-docs",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server that provides tools to search and fetch QMK Firmware docs (docs.qmk.fm)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "node --enable-source-maps --watch dist/server.js",
    "test:client": "node dist/testClient.js",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "node-html-parser": "^6.1.13",
    "fast-xml-parser": "^4.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.12"
  }
}


