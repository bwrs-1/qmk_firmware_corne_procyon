.git
.gitignore
.gitmodules

# ビルド成果物
*.bin
*.hex
*.uf2
*.elf
.build/
build/

# エディタ・IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 一時ファイル
*.tmp
*.log
*.cache

# Node.js関連（docs用）
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Python関連
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/

# Docker関連
Dockerfile
docker-compose.yml
.dockerignore
README-Docker.md
docker-build.sh
docker-build.ps1

# 文書・設計資料
docs/
*.md
*.txt

# テスト関連
.pytest_cache/
.coverage
htmlcov/

