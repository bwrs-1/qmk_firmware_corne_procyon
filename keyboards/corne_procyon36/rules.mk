# ============================================================================
# Corne Procyon36 キーボード設定ファイル
# ============================================================================
# このファイルは、QMKファームウェアのビルド設定を定義します
# 各設定項目の詳細は、QMK公式ドキュメントを参照してください

# ============================================================================
# ドライバー設定
# ============================================================================
SERIAL_DRIVER = vendor                    # ベンダー提供のシリアルドライバーを使用
I2C_DRIVER_REQUIRED = yes                 # I2Cドライバーの使用を必須化

# DIGITIZER_DRIVER = maxtouch               # 削除 (QMK標準にないため)
POINTING_DEVICE_DRIVER = digitizer        # ポインティングデバイスとしてデジタイザーを使用
SRC += maxtouch.c                         # ローカルのmaxtouchドライバーを使用

# ============================================================================
# デバッグ設定
# ============================================================================
MAXTOUCH_DEBUG = no                       # Maxtouchデバッグ出力を無効化（VIA と raw_hid_receive 重複を回避）
CONSOLE_ENABLE = yes                      # HID コンソール出力を有効化（デバッグ用）
DEBUG_ENABLE = yes                        # dprintf/uprintf を有効化（デバッグ出力用）

# ============================================================================
# ソースファイル
# ============================================================================
SRC += digitizer_user.c                   # カスタムデジタイザー処理を追加